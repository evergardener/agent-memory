# Generate a private runtime file with scripts/init-predeploy-env.sh.
# Never copy this template directly into a running deployment.
AGENT_MEMORY_VERSION=1.0.0-rc.7
AGENT_MEMORY_REVISION=replace-with-the-full-git-revision
AGENT_MEMORY_DEPLOYMENT_TIER=predeploy
AGENT_MEMORY_COMPOSE_PROJECT=agent-memory-predeploy-rc7
AGENT_MEMORY_IMAGE_PREFIX=agent-memory-predeploy-rc7
AGENT_MEMORY_POSTGRES_DATA_DIR=/private/tmp/agent-memory-predeploy-rc7/postgres
AGENT_MEMORY_BACKEND_SUBNET=172.16.250.0/24
AGENT_MEMORY_EDGE_SUBNET=172.16.251.0/24
AGENT_MEMORY_VAULT_ROOT_KEY_HOST_FILE=/private/tmp/agent-memory-predeploy-rc7/vault_root_key
AGENT_MEMORY_PREDEPLOY_BACKUP_ROOT=/private/tmp/agent-memory-predeploy-rc7/backups
AGENT_MEMORY_PREDEPLOY_STATE_FILE=/private/tmp/agent-memory-predeploy-rc7/PREDEPLOY-STATE.json

AGENT_MEMORY_DB_PASSWORD=replace-with-a-new-predeploy-only-random-password
AGENT_MEMORY_SERVICE_TOKEN=replace-with-a-new-predeploy-only-random-token
AGENT_MEMORY_NAMESPACE=hermes:predeploy-rc7
AGENT_MEMORY_API_PORT=7810
AGENT_MEMORY_IMPORT_NAMESPACE=hermes:predeploy-rc7-import
AGENT_MEMORY_IMPORT_API_PORT=7811
AGENT_MEMORY_LOG_LEVEL=INFO
AGENT_MEMORY_WORKER_POLL_SECONDS=0.5
AGENT_MEMORY_WORKER_LEASE_SECONDS=180
AGENT_MEMORY_VAULT_ROOT_KEY_FILE=/run/secrets/vault_root_key
AGENT_MEMORY_UI_PASSWORD_HASH=replace-with-a-new-predeploy-only-scrypt-hash
AGENT_MEMORY_UI_SESSION_SECRET=replace-with-a-new-predeploy-only-random-ui-session-secret
AGENT_MEMORY_REPORT_INTERVAL_DAYS=7
AGENT_MEMORY_CANDIDATE_RETENTION_DAYS=30
AGENT_MEMORY_CURRENT_STATE_DAYS=7
AGENT_MEMORY_WEATHER_STATE_HOURS=24
AGENT_MEMORY_CONTINUITY_DAYS=14
AGENT_MEMORY_STAGE_DORMANT_DAYS=90
AGENT_MEMORY_STAGE_FORGET_DAYS=365
AGENT_MEMORY_MODEL_ENABLED=false
AGENT_MEMORY_IMPORT_MODEL_ENABLED=false
AGENT_MEMORY_MODEL_NAME=
AGENT_MEMORY_MODEL_API_BASE=
AGENT_MEMORY_MODEL_API_KEY=
AGENT_MEMORY_MODEL_TIMEOUT_SECONDS=30
AGENT_MEMORY_MODEL_MAX_RETRIES=2
AGENT_MEMORY_MODEL_BACKFILL_BATCH_SIZE=25
AGENT_MEMORY_MODEL_MAX_ATOMIC_FACTS=8
AGENT_MEMORY_MODEL_ALLOW_EXTERNAL_DATA=false
AGENT_MEMORY_TRUSTED_OBSERVATION_TOOL_ALLOWLIST=terminal,exec,execute_code,shell,health_probe
