# Copy to a chmod 600 file outside Git, replace every placeholder, then run
# scripts/release-preflight.sh before scripts/release-check.sh.
AGENT_MEMORY_VERSION=1.0.0-rc.8
AGENT_MEMORY_RELEASE_ISOLATED=true
AGENT_MEMORY_COMPOSE_PROJECT=agent-memory-release-rc7
AGENT_MEMORY_IMAGE_PREFIX=agent-memory-release-rc7
AGENT_MEMORY_POSTGRES_DATA_DIR=/private/tmp/agent-memory-release-rc7/postgres
AGENT_MEMORY_BACKEND_SUBNET=172.16.246.0/24
AGENT_MEMORY_EDGE_SUBNET=172.16.247.0/24
AGENT_MEMORY_VAULT_ROOT_KEY_HOST_FILE=/private/tmp/agent-memory-release-rc7/vault_root_key
AGENT_MEMORY_RELEASE_BACKUP_ROOT=/private/tmp/agent-memory-release-rc7/backups

AGENT_MEMORY_DB_PASSWORD=replace-with-a-new-release-only-random-password
AGENT_MEMORY_SERVICE_TOKEN=replace-with-a-new-release-only-random-token
AGENT_MEMORY_NAMESPACE=hermes:automated-tests-rc7
AGENT_MEMORY_API_PORT=7799
AGENT_MEMORY_IMPORT_NAMESPACE=hermes:automated-tests-rc7-import
AGENT_MEMORY_IMPORT_API_PORT=7800
AGENT_MEMORY_AUTOMATED_NAMESPACE=hermes:automated-tests-rc7-regression
AGENT_MEMORY_AUTOMATED_API_PORT=7801
AGENT_MEMORY_RELEASE_POSTGRES_PORT=7805
AGENT_MEMORY_LOG_LEVEL=INFO
AGENT_MEMORY_WORKER_POLL_SECONDS=0.5
AGENT_MEMORY_WORKER_LEASE_SECONDS=180
AGENT_MEMORY_VAULT_ROOT_KEY_FILE=/run/secrets/vault_root_key
AGENT_MEMORY_UI_PASSWORD_HASH=replace-with-a-new-release-only-scrypt-hash
AGENT_MEMORY_TEST_UI_PASSWORD=replace-with-a-new-release-only-ui-test-password
AGENT_MEMORY_UI_SESSION_SECRET=replace-with-a-new-release-only-random-ui-session-secret
AGENT_MEMORY_REPORT_INTERVAL_DAYS=7
AGENT_MEMORY_CANDIDATE_RETENTION_DAYS=30
AGENT_MEMORY_CURRENT_STATE_DAYS=7
AGENT_MEMORY_WEATHER_STATE_HOURS=24
AGENT_MEMORY_CONTINUITY_DAYS=14
AGENT_MEMORY_STAGE_DORMANT_DAYS=90
AGENT_MEMORY_STAGE_FORGET_DAYS=365
AGENT_MEMORY_MODEL_ENABLED=false
AGENT_MEMORY_IMPORT_MODEL_ENABLED=false
AGENT_MEMORY_MODEL_NAME=
AGENT_MEMORY_MODEL_API_BASE=
AGENT_MEMORY_MODEL_API_KEY=
AGENT_MEMORY_MODEL_TIMEOUT_SECONDS=30
AGENT_MEMORY_MODEL_MAX_RETRIES=2
AGENT_MEMORY_MODEL_BACKFILL_BATCH_SIZE=25
AGENT_MEMORY_MODEL_MAX_ATOMIC_FACTS=8
AGENT_MEMORY_MODEL_ALLOW_EXTERNAL_DATA=false
AGENT_MEMORY_TRUSTED_OBSERVATION_TOOL_ALLOWLIST=terminal,exec,execute_code,shell,health_probe
